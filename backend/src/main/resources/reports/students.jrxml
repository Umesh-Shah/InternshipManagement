<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="students" pageWidth="842" pageHeight="595" orientation="Landscape"
              columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              whenNoDataType="AllSectionsNoDetail">

    <field name="studentId"        class="java.lang.Integer"/>
    <field name="fname"            class="java.lang.String"/>
    <field name="lname"            class="java.lang.String"/>
    <field name="year"             class="java.lang.Integer"/>
    <field name="country"          class="java.lang.String"/>
    <field name="semester"         class="java.lang.String"/>
    <field name="internshipStatus" class="java.lang.String"/>
    <field name="studentStatus"    class="java.lang.String"/>

    <title>
        <band height="40">
            <staticText>
                <reportElement x="0" y="5" width="802" height="30"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[Student Report]]></text>
            </staticText>
        </band>
    </title>

    <columnHeader>
        <band height="22" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="802" height="22" backcolor="#4472C4" forecolor="#4472C4"/>
                <graphicElement>
                    <pen lineWidth="0"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0"   y="2" width="50"  height="18" forecolor="#FFFFFF"/>
                <textElement><font isBold="true" size="9"/></textElement>
                <text><![CDATA[ID]]></text>
            </staticText>
            <staticText>
                <reportElement x="50"  y="2" width="100" height="18" forecolor="#FFFFFF"/>
                <textElement><font isBold="true" size="9"/></textElement>
                <text><![CDATA[First Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="150" y="2" width="100" height="18" forecolor="#FFFFFF"/>
                <textElement><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Last Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="250" y="2" width="52"  height="18" forecolor="#FFFFFF"/>
                <textElement><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Year]]></text>
            </staticText>
            <staticText>
                <reportElement x="302" y="2" width="100" height="18" forecolor="#FFFFFF"/>
                <textElement><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Country]]></text>
            </staticText>
            <staticText>
                <reportElement x="402" y="2" width="100" height="18" forecolor="#FFFFFF"/>
                <textElement><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Semester]]></text>
            </staticText>
            <staticText>
                <reportElement x="502" y="2" width="150" height="18" forecolor="#FFFFFF"/>
                <textElement><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Internship Status]]></text>
            </staticText>
            <staticText>
                <reportElement x="652" y="2" width="150" height="18" forecolor="#FFFFFF"/>
                <textElement><font isBold="true" size="9"/></textElement>
                <text><![CDATA[Student Status]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="18" splitType="Stretch">
            <textField isBlankWhenNull="true">
                <reportElement x="0"   y="1" width="50"  height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{studentId}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="50"  y="1" width="100" height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{fname}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="150" y="1" width="100" height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{lname}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="250" y="1" width="52"  height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{year}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="302" y="1" width="100" height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{country}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="402" y="1" width="100" height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{semester}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="502" y="1" width="150" height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{internshipStatus}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="652" y="1" width="150" height="16"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{studentStatus}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <noData>
        <band height="30">
            <staticText>
                <reportElement x="0" y="5" width="802" height="20"/>
                <textElement textAlignment="Center"><font size="11"/></textElement>
                <text><![CDATA[No data found for the selected filters.]]></text>
            </staticText>
        </band>
    </noData>

</jasperReport>
